FINNHUB_API_KEY=your_finnhub_api_key_here

# Screener settings
UNIVERSE=all                # all | sp500 | swing
MODE=all                    # all | prebreakout | breakout
SOURCE=confluence           # local | tv | confluence
TOP=30
NO_FINNHUB=false

# Filter settings
MIN_PRICE=5.0
MIN_AVG_VOL=500000
MIN_MARKET_CAP=2000000000

# Trade plan settings
ACCOUNT_SIZE=1500.0
RISK_PCT=0.01               # 1% of account per trade
MIN_ADR_PCT=1.8             # min avg daily range %
MIN_RR=1.5                  # min reward:risk ratio
STOP_ATR_MULT=1.5           # stop = entry - N × ATR(14)
TARGET_ATR_MULT=2.5         # target = entry + N × ATR(14)
TRADABLE_ONLY=false
